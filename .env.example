# ------------------------
# Public ports
# ------------------------
MONEROPAY_PORT=5000
BACKEND_PORT=8080
BACKEND_DB_PORT=55432

# ------------------------
# MoneroPay database
# ------------------------
MONEROPAY_POSTGRES_USERNAME=moneropay
MONEROPAY_POSTGRES_PASSWORD=
MONEROPAY_POSTGRES_DATABASE=moneropay

# ------------------------
# Monero daemon
# ------------------------
MONERO_DAEMON_RPC_HOSTNAME=xmr-node.cakewallet.com
MONERO_DAEMON_RPC_PORT=18081
MONERO_DAEMON_RPC_USERNAME=
MONERO_DAEMON_RPC_PASSWORD=

# ------------------------
# Backend admin
# ------------------------
ADMIN_NAME=admin
ADMIN_PASSWORD=

# ------------------------
# Backend database
# ------------------------
DB_HOST=backend-db
DB_USER=moneromerchant
DB_PASSWORD=
DB_NAME=moneromerchant
DB_PORT=5432

# ------------------------
# Backend JWT secrets
# ------------------------
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_MONEROPAY_SECRET=
JWT_LWS_TOKEN=

# ------------------------
# Backend → MoneroPay
# ------------------------
MONEROPAY_BASE_URL=http://moneropay:5000
MONEROPAY_CALLBACK_URL=http://backend:8080/callback/

# ------------------------
# Monero RPC (backend)
# ------------------------
MONERO_DAEMON_RPC_ENDPOINT=http://xmr-node.cakewallet.com:18081/json_rpc
MONERO_WALLET_RPC_ENDPOINT=http://monero-wallet-rpc:28081/json_rpc
MONERO_WALLET_RPC_USERNAME=
MONERO_WALLET_RPC_PASSWORD=

# ------------------------
# Wallet
# ------------------------
WALLET_NAME=wallet
WALLET_PASSWORD=
WALLET_AUTO_REFRESH_PERIOD=2
